<div id="MobileBanners-{{ section.id }}" class="mobile-banners">
  {%- for block in section.blocks -%}
    <div class="mobile-banners__item" {{ block.shopify_attributes }}>
      <a href="{{ block.settings.link }}" class="mobile-banners__link">
        {%- if block.settings.media_type == 'video' and block.settings.video != blank -%}
          <div class="mobile-banners__media">
            {{ block.settings.video
              | video_tag:
                autoplay: true,
                loop: true,
                controls: false,
                muted: true,
                playsinline: true,
                class: 'mobile-banners__video'
            }}
          </div>
        {%- elsif block.settings.image != blank -%}
          <img
            srcset="{%- if block.settings.image.width >= 375 -%}{{ block.settings.image | image_url: width: 375 }} 375w,{%- endif -%}
              {%- if block.settings.image.width >= 550 -%}{{ block.settings.image | image_url: width: 550 }} 550w,{%- endif -%}
              {%- if block.settings.image.width >= 750 -%}{{ block.settings.image | image_url: width: 750 }} 750w,{%- endif -%}
              {%- if block.settings.image.width >= 1080 -%}{{ block.settings.image | image_url: width: 1080 }} 1080w,{%- endif -%}
              {%- if block.settings.image.width >= 1500 -%}{{ block.settings.image | image_url: width: 1500 }} 1500w,{%- endif -%}
              {{ block.settings.image | image_url }} {{ block.settings.image.width }}w"
            sizes="100vw"
            src="{{ block.settings.image | image_url: width: 750 }}"
            alt="{{ block.settings.image.alt | escape }}"
            class="mobile-banners__image"
            loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
            fetchpriority="{% if forloop.first %}high{% else %}low{% endif %}"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
          >
        {%- else -%}
          {{ 'hero-apparel-1' | placeholder_svg_tag: 'mobile-banners__image' }}
        {%- endif -%}
      </a>

      {%- if block.settings.heading != blank or block.settings.subheading != blank or block.settings.button_label != blank -%}
        <div class="mobile-banners__overlay">
          {%- if block.settings.heading != blank -%}
            <p class="mobile-banners__heading">{{ block.settings.heading }}</p>
          {%- endif -%}
          {%- if block.settings.subheading != blank -%}
            <p class="mobile-banners__subheading">{{ block.settings.subheading }}</p>
          {%- endif -%}
          {%- if block.settings.button_label != blank -%}
            <a href="{{ block.settings.link }}" class="button mobile-banners__button">
              {{ block.settings.button_label }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  {%- endfor -%}
</div>

{% stylesheet %}
  .mobile-banners {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .mobile-banners {
      display: block;
    }

    .mobile-banners__item {
      position: relative;
      width: 100%;
      height: 100svh;
      height: 100dvh;
      overflow: hidden;
    }

    .mobile-banners__link {
      display: block;
      width: 100%;
      height: 100%;
    }

    .mobile-banners__image,
    .mobile-banners__video,
    .mobile-banners__media {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center center;
      display: block;
    }

    .mobile-banners__media {
      position: relative;
    }

    .mobile-banners__media video {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .mobile-banners__overlay {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 24px 16px 40px;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      z-index: 2;
      background: linear-gradient(to top, rgba(0, 0, 0, 0.4) 0%, transparent 100%);
    }

    .mobile-banners__heading {
      color: #fff;
      font-size: 1.25rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      line-height: 1.3;
      margin: 0 0 4px;
      text-transform: uppercase;
    }

    .mobile-banners__subheading {
      color: #fff;
      font-size: 0.875rem;
      font-weight: 400;
      line-height: 1.4;
      margin: 0 0 16px;
    }

    .mobile-banners__button {
      display: inline-block;
      text-decoration: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Mobile Banners",
  "tag": "section",
  "class": "mobile-banners-wrapper",
  "blocks": [
    {
      "type": "banner",
      "name": "Banner",
      "settings": [
        {
          "type": "select",
          "id": "media_type",
          "label": "Media type",
          "options": [
            { "value": "image", "label": "Image" },
            { "value": "video", "label": "Video" }
          ],
          "default": "image"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "HEADING"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "SHOP NOW"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mobile Banners",
      "category": "Banners",
      "blocks": [
        {
          "type": "banner",
          "settings": {
            "heading": "HEADING",
            "button_label": "SHOP NOW"
          }
        }
      ]
    }
  ]
}
{% endschema %}
